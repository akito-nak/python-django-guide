# ============================================================
# .gitignore for Python / Django / AI projects
# ============================================================

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak

# ── Environment variables — NEVER commit these! ───────────────
.env
.env.local
.env.development
.env.production
.env.test
*.env

# ── Django ────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
.cache/

# ── Database migrations (optional — some teams commit these)
# migrations/  ← leave this commented: DO commit migrations

# ── Testing & Coverage ────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.pytest_cache/
.hypothesis/
nosetests.xml
test-results/

# ── Type checking ─────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── IDEs & Editors ────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
*.sublime-project
*.sublime-workspace

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ───────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Linux ─────────────────────────────────────────────────────
*~

# ── Jupyter Notebooks ─────────────────────────────────────────
.ipynb_checkpoints
*.ipynb      # ← comment out if you want to commit notebooks
profile_default/
ipython_config.py

# ── AI / ML ───────────────────────────────────────────────────
# Trained models (large files — use DVC or MLflow instead)
models/
*.pkl
*.joblib
*.h5
*.ckpt
*.pt
*.pth
*.bin
*.safetensors

# Vector databases
chroma_db/
*.faiss
*.index

# Dataset files (store in S3/GCS instead)
data/
datasets/
*.csv
*.parquet
*.jsonl
*.arrow

# Weights & Biases / MLflow artifacts
wandb/
mlruns/
mlflow/

# ── Docker ────────────────────────────────────────────────────
# Don't ignore docker-compose files — they're config, not secrets

# ── Node (if using webpack/tailwind build) ────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Celery ────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Docs build ────────────────────────────────────────────────
docs/_build/
site/

# ── Temporary files ───────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup
